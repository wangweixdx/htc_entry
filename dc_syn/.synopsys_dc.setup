# =============================================================================
# ATC Synthesis - Synopsys DC Setup File
# Target: SF4X @ 1GHz (using GTECH generic for feasibility)
# =============================================================================

# --- Library paths ---
set DC_LIB_PATH    "/usr/Synopsys/syn/T-2022.03-SP2/libraries/syn"
set DW_PATH        "/usr/Synopsys/syn/T-2022.03-SP2/dw"

# --- Search path ---
set_app_var search_path [list . \
    /home/host/claude_code_work/atc/dc_syn \
    /home/host/claude_code_work/atc/rtl \
    $DC_LIB_PATH \
    $DW_PATH/dw01/lib \
    $DW_PATH/dw02/lib \
    $DW_PATH/dw03/lib \
    $DW_PATH/dw04/lib \
    $DW_PATH/dw05/lib \
    $DW_PATH/dw06/lib \
    $DW_PATH/sim_ver \
    $DW_PATH/syn_ver \
]

# --- Technology libraries ---
set_app_var target_library  "$DC_LIB_PATH/gtech.db $DC_LIB_PATH/class.db"
set_app_var link_library    "* $DC_LIB_PATH/gtech.db $DC_LIB_PATH/class.db $DC_LIB_PATH/dw_foundation.sldb $DC_LIB_PATH/standard.sldb"
set_app_var synthetic_library "$DC_LIB_PATH/dw_foundation.sldb $DC_LIB_PATH/standard.sldb"

# --- Symbol library ---
set_app_var symbol_library  "$DC_LIB_PATH/generic.sdb $DC_LIB_PATH/class.sdb"

# --- Enable SystemVerilog ---
set svr_keep_ext_dir true
set_app_var hdlin_auto_save_templates true
set_app_var hdlin_sverilog_std "2012"

# --- Suppress common warnings ---
suppress_message "UID-401"
suppress_message "LINT-1"

echo "--- ATC DC Setup loaded ---"
echo "  target_library:  [get_app_var target_library]"
echo "  link_library:    [get_app_var link_library]"
